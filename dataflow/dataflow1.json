{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "InputData",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "OutputData",
						"type": "DatasetReference"
					},
					"name": "BikeData"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Region as string,",
				"          Country as string,",
				"          Customer as string,",
				"          BusinessSegment as string,",
				"          Category as string,",
				"          Model as string,",
				"          Color as string,",
				"          SalesDate as string,",
				"          ListPrice as double,",
				"          UnitPrice as double,",
				"          OrderQty as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(Cost = OrderQty*UnitPrice,",
				"          Sales = OrderQty*ListPrice) ~> derivedColumn1",
				"derivedColumn1 derive(Profit = Sales - Cost) ~> derivedColumn2",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> BikeData"
			]
		}
	}
}